{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "IAM Role Set",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "name": {
      "type": "string",
      "description": "Optional name. Defaults to filename if not set."
    },
    "roles": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "List of roles in this set."
    }
  },
  "required": ["roles"]
}
