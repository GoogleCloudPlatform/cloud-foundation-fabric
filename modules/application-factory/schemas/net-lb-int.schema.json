{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Internal TCP/UDP Load Balancer",
  "type": "object",
  "additionalProperties": false,
  "required": ["region", "vpc_config"],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "Override resource name derived from filename."
    },
    "region": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "service_label": {
      "type": "string"
    },
    "vpc_config": {
      "type": "object",
      "required": ["network", "subnetwork"],
      "additionalProperties": false,
      "properties": {
        "network": { "type": "string" },
        "subnetwork": { "type": "string" }
      }
    },
    "backend_service_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "connection_draining_timeout_sec": { "type": "number" },
        "connection_tracking": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "idle_timeout_sec": { "type": "number" },
            "persist_conn_on_unhealthy": { "type": "string" },
            "track_per_session": { "type": "boolean" }
          }
        },
        "enable_subsetting": { "type": "boolean" },
        "failover_config": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "disable_conn_drain": { "type": "boolean" },
            "drop_traffic_if_unhealthy": { "type": "boolean" },
            "ratio": { "type": "number" }
          }
        },
        "log_sample_rate": { "type": "number" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "protocol": { "type": "string" },
        "session_affinity": { "type": "string" },
        "timeout_sec": { "type": "number" }
      }
    },
    "backends": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["group"],
        "additionalProperties": false,
        "properties": {
          "group": { "type": "string" },
          "description": { "type": "string" },
          "failover": { "type": "boolean" }
        }
      }
    },
    "forwarding_rules_config": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "address": { "type": "string" },
          "description": { "type": "string" },
          "global_access": { "type": "boolean" },
          "ipv6": { "type": "boolean" },
          "name": { "type": "string" },
          "ports": {
            "type": "array",
            "items": { "type": "string" }
          },
          "protocol": { "type": "string" }
        }
      }
    },
    "group_configs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["zone"],
        "additionalProperties": false,
        "properties": {
          "zone": { "type": "string" },
          "name": { "type": "string" },
          "description": { "type": "string" },
          "instances": {
            "type": "array",
            "items": { "type": "string" }
          },
          "named_ports": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          }
        }
      }
    },
    "health_check": {
      "type": "string"
    },
    "health_check_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "check_interval_sec": { "type": "number" },
        "description": { "type": "string" },
        "enable_logging": { "type": "boolean" },
        "healthy_threshold": { "type": "number" },
        "is_regional": { "type": "boolean" },
        "name": { "type": "string" },
        "timeout_sec": { "type": "number" },
        "unhealthy_threshold": { "type": "number" },
        "http": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "number" },
            "port_name": { "type": "string" },
            "port_specification": { "type": "string" },
            "proxy_header": { "type": "string" },
            "request_path": { "type": "string" },
            "response": { "type": "string" }
          }
        },
        "https": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "host": { "type": "string" },
            "port": { "type": "number" },
            "port_name": { "type": "string" },
            "port_specification": { "type": "string" },
            "proxy_header": { "type": "string" },
            "request_path": { "type": "string" },
            "response": { "type": "string" }
          }
        },
        "tcp": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "number" },
            "port_name": { "type": "string" },
            "port_specification": { "type": "string" },
            "proxy_header": { "type": "string" },
            "request": { "type": "string" },
            "response": { "type": "string" }
          }
        },
        "grpc": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "port": { "type": "number" },
            "port_name": { "type": "string" },
            "port_specification": { "type": "string" },
            "service_name": { "type": "string" }
          }
        }
      }
    }
  }
}
