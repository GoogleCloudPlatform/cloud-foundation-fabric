{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Secret Manager",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string"
    },
    "secrets": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "annotations": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "deletion_protection": { "type": "boolean" },
          "kms_key": { "type": "string" },
          "labels": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "global_replica_locations": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "location": { "type": "string" },
          "tag_bindings": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "tags": {
            "type": "object",
            "additionalProperties": { "type": "string" }
          },
          "expiration_config": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "time": { "type": "string" },
              "ttl": { "type": "string" }
            }
          },
          "iam": {
            "type": "object",
            "additionalProperties": {
              "type": "array",
              "items": { "type": "string" }
            }
          },
          "iam_bindings": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["members", "role"],
              "additionalProperties": false,
              "properties": {
                "members": { "type": "array", "items": { "type": "string" } },
                "role": { "type": "string" },
                "condition": {
                  "type": "object",
                  "required": ["expression", "title"],
                  "additionalProperties": false,
                  "properties": {
                    "expression": { "type": "string" },
                    "title": { "type": "string" },
                    "description": { "type": "string" }
                  }
                }
              }
            }
          },
          "iam_bindings_additive": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["member", "role"],
              "additionalProperties": false,
              "properties": {
                "member": { "type": "string" },
                "role": { "type": "string" },
                "condition": {
                  "type": "object",
                  "required": ["expression", "title"],
                  "additionalProperties": false,
                  "properties": {
                    "expression": { "type": "string" },
                    "title": { "type": "string" },
                    "description": { "type": "string" }
                  }
                }
              }
            }
          },
          "version_config": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "aliases": {
                "type": "object",
                "additionalProperties": { "type": "number" }
              },
              "destroy_ttl": { "type": "string" }
            }
          },
          "versions": {
            "type": "object",
            "additionalProperties": {
              "type": "object",
              "required": ["data"],
              "additionalProperties": false,
              "properties": {
                "data": { "type": "string" },
                "deletion_policy": {
                  "type": "string",
                  "enum": ["DELETE", "DISABLE", "ABANDON"]
                },
                "enabled": { "type": "boolean" },
                "data_config": {
                  "type": "object",
                  "additionalProperties": false,
                  "properties": {
                    "is_base64": { "type": "boolean" },
                    "is_file": { "type": "boolean" },
                    "write_only_version": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
