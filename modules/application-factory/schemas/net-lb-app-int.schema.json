{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Internal Application Load Balancer",
  "type": "object",
  "additionalProperties": false,
  "required": ["region", "vpc_config"],
  "properties": {
    "project_id": {
      "type": "string"
    },
    "name": {
      "type": "string",
      "description": "Override resource name derived from filename."
    },
    "region": {
      "type": "string"
    },
    "description": {
      "type": "string"
    },
    "labels": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    },
    "protocol": {
      "type": "string",
      "enum": ["HTTP", "HTTPS"]
    },
    "ports": {
      "type": "array",
      "items": { "type": "string" },
      "maxItems": 1
    },
    "address": {
      "type": "string"
    },
    "global_access": {
      "type": "boolean"
    },
    "vpc_config": {
      "type": "object",
      "required": ["network", "subnetwork"],
      "additionalProperties": false,
      "properties": {
        "network": { "type": "string" },
        "subnetwork": { "type": "string" }
      }
    },
    "backend_service_configs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["backends"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "health_checks": {
            "type": "array",
            "items": { "type": "string" }
          },
          "port_name": { "type": "string" },
          "protocol": { "type": "string" },
          "session_affinity": { "type": "string" },
          "timeout_sec": { "type": "number" },
          "log_sample_rate": { "type": "number" },
          "backends": {
            "type": "array",
            "items": {
              "type": "object",
              "required": ["group"],
              "additionalProperties": false,
              "properties": {
                "group": { "type": "string" },
                "balancing_mode": { "type": "string" },
                "capacity_scaler": { "type": "number" },
                "description": { "type": "string" },
                "failover": { "type": "boolean" },
                "max_utilization": { "type": "number" }
              }
            }
          }
        }
      }
    },
    "group_configs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "required": ["zone"],
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "description": { "type": "string" },
          "zone": { "type": "string" },
          "instances": {
            "type": "array",
            "items": { "type": "string" }
          },
          "named_ports": {
            "type": "object",
            "additionalProperties": { "type": "number" }
          },
          "project_id": { "type": "string" }
        }
      }
    },
    "neg_configs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "project_id": { "type": "string" },
          "description": { "type": "string" },
          "cloudrun": {
            "type": "object",
            "required": ["region"],
            "additionalProperties": false,
            "properties": {
              "region": { "type": "string" },
              "tag": { "type": "string" },
              "target_urlmask": { "type": "string" },
              "target_service": {
                "type": "object",
                "required": ["name"],
                "additionalProperties": false,
                "properties": {
                  "name": { "type": "string" },
                  "tag": { "type": "string" }
                }
              }
            }
          },
          "gce": {
            "type": "object",
            "required": ["zone"],
            "additionalProperties": false,
            "properties": {
              "zone": { "type": "string" },
              "network": { "type": "string" },
              "subnetwork": { "type": "string" },
              "endpoints": {
                "type": "object",
                "additionalProperties": {
                  "type": "object",
                  "required": ["instance", "ip_address", "port"],
                  "additionalProperties": false,
                  "properties": {
                    "instance": { "type": "string" },
                    "ip_address": { "type": "string" },
                    "port": { "type": "number" }
                  }
                }
              }
            }
          }
        }
      }
    },
    "health_check_configs": {
      "type": "object",
      "additionalProperties": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "name": { "type": "string" },
          "check_interval_sec": { "type": "number" },
          "description": { "type": "string" },
          "enable_logging": { "type": "boolean" },
          "healthy_threshold": { "type": "number" },
          "timeout_sec": { "type": "number" },
          "unhealthy_threshold": { "type": "number" },
          "http": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string" },
              "port": { "type": "number" },
              "port_name": { "type": "string" },
              "port_specification": { "type": "string" },
              "proxy_header": { "type": "string" },
              "request_path": { "type": "string" },
              "response": { "type": "string" }
            }
          },
          "https": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "host": { "type": "string" },
              "port": { "type": "number" },
              "port_name": { "type": "string" },
              "port_specification": { "type": "string" },
              "proxy_header": { "type": "string" },
              "request_path": { "type": "string" },
              "response": { "type": "string" }
            }
          },
          "grpc": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "port": { "type": "number" },
              "port_name": { "type": "string" },
              "port_specification": { "type": "string" },
              "service_name": { "type": "string" }
            }
          }
        }
      }
    },
    "urlmap_config": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "description": { "type": "string" },
        "default_service": { "type": "string" },
        "default_url_redirect": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "host": { "type": "string" },
            "https": { "type": "boolean" },
            "path": { "type": "string" },
            "prefix": { "type": "string" },
            "response_code": { "type": "string" },
            "strip_query": { "type": "boolean" }
          }
        },
        "host_rules": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["hosts", "path_matcher"],
            "additionalProperties": false,
            "properties": {
              "hosts": { "type": "array", "items": { "type": "string" } },
              "path_matcher": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        },
        "path_matchers": {
          "type": "object",
          "additionalProperties": {
            "type": "object",
            "additionalProperties": false,
            "properties": {
              "description": { "type": "string" },
              "default_service": { "type": "string" },
              "path_rules": {
                "type": "array",
                "items": {
                  "type": "object",
                  "required": ["paths", "service"],
                  "additionalProperties": false,
                  "properties": {
                    "paths": { "type": "array", "items": { "type": "string" } },
                    "service": { "type": "string" }
                  }
                }
              }
            }
          }
        }
      }
    }
  }
}
