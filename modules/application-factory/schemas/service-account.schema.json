{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Service Account",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "project_id": {
      "type": "string",
      "description": "Project id where service account will be created."
    },
    "name": {
      "type": "string",
      "description": "Override resource name derived from filename."
    },
    "description": {
      "type": "string"
    },
    "display_name": {
      "type": "string"
    },
    "prefix": {
      "type": "string"
    },
    "iam": {
      "$ref": "#/$defs/iam"
    },
    "iam_bindings": {
      "$ref": "#/$defs/iam_bindings"
    },
    "iam_bindings_additive": {
      "$ref": "#/$defs/iam_bindings_additive"
    },
    "iam_by_principals": {
      "$ref": "#/$defs/iam_by_principals"
    },
    "iam_billing_roles": {
      "type": "object",
      "description": "Billing account roles granted to this SA, by billing account id.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "iam_folder_roles": {
      "type": "object",
      "description": "Folder roles granted to this SA, by folder id.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "iam_organization_roles": {
      "type": "object",
      "description": "Organization roles granted to this SA, by organization id.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "iam_project_roles": {
      "type": "object",
      "description": "Project roles granted to this SA, by project id.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "iam_sa_roles": {
      "type": "object",
      "description": "SA roles granted to this SA, by service account name.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "iam_storage_roles": {
      "type": "object",
      "description": "Storage roles granted to this SA, by bucket name.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "tag_bindings": {
      "type": "object",
      "additionalProperties": { "type": "string" }
    }
  },
  "$defs": {
    "iam": {
      "type": "object",
      "description": "IAM bindings in {ROLE => [MEMBERS]} format.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    },
    "iam_bindings": {
      "type": "object",
      "description": "Authoritative IAM bindings.",
      "additionalProperties": {
        "type": "object",
        "required": ["members", "role"],
        "additionalProperties": false,
        "properties": {
          "members": {
            "type": "array",
            "items": { "type": "string" }
          },
          "role": { "type": "string" },
          "condition": {
            "type": "object",
            "required": ["expression", "title"],
            "additionalProperties": false,
            "properties": {
              "expression": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "iam_bindings_additive": {
      "type": "object",
      "description": "Individual additive IAM bindings.",
      "additionalProperties": {
        "type": "object",
        "required": ["member", "role"],
        "additionalProperties": false,
        "properties": {
          "member": { "type": "string" },
          "role": { "type": "string" },
          "condition": {
            "type": "object",
            "required": ["expression", "title"],
            "additionalProperties": false,
            "properties": {
              "expression": { "type": "string" },
              "title": { "type": "string" },
              "description": { "type": "string" }
            }
          }
        }
      }
    },
    "iam_by_principals": {
      "type": "object",
      "description": "IAM binding in {PRINCIPAL => [ROLES]} format.",
      "additionalProperties": {
        "type": "array",
        "items": { "type": "string" }
      }
    }
  }
}
